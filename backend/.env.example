# Copy this file to `.env` in the same directory and fill in real values.
# `.env` is gitignored and loaded automatically by Spring Boot via
# `spring.config.import=optional:file:./.env[.properties]` in application.properties.
# Run the app from the `backend/` directory so the relative path resolves.

DB_PASSWORD=your-local-db-password

# Any long random string works for local dev. For prod, set APP_JWT_SECRET as a real env var.
APP_JWT_SECRET=replace-with-a-long-random-dev-secret

# Optional overrides (commented = use defaults from application.properties)
# DB_USERNAME=root
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# APP_JWT_EXPIRATION_MS=86400000
