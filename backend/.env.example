# Backend env template. Copy to .env and fill in.
# Loaded by Spring via spring.config.import in application.properties.

# DB_USERNAME= MySQL username.
# Required: MySQL password for the configured DB_USERNAME.
DB_PASSWORD=

# Required: secret key for JWT signing. Any long random string (>=32 chars).
APP_JWT_SECRET=

# Required for production:
RESEND_API_KEY=
RESEND_FROM_EMAIL=
APP_CORS_ALLOWED_ORIGINS=
APP_FRONTEND_URL=

# Optional overrides (defaults shown):
# DB_URL=jdbc:mysql://localhost:3306/roamroute
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# APP_FRONTEND_URL=http://localhost:5173
# APP_JWT_EXPIRATION_MS=86400000
# APP_UPLOAD_DIR=./storage/images
# APP_UPLOAD_URL_PREFIX=/images
